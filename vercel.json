{
  "version": 2,
  "outputDirectory": "build/web",
  "buildCommand": "bash build.sh",
  "installCommand": "echo 'Dependencies handled in build script'",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}